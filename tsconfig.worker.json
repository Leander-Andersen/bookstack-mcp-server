{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "outDir": "dist-worker",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-worker",
    "tests",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
